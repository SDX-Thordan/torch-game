; TORCH — Godot 4.2 project (renderer/shell over the Rust core, §26).
; Engine configuration file. Edited by hand for the toolchain de-risk; the editor
; will rewrite/extend it as scenes are added.

config_version=5

[application]

config/name="TORCH"
config/description="Hard sci-fi industrial sandbox. Godot shell over a Rust deterministic core."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
; Resizable so the desktop (PC mode) window can be sized/maximized; the HUD scales
; via the expand stretch below. Ignored on handhelds.
window/size/resizable=true
; Landscape, auto-rotating between the two landscape directions (mobile, §17).
; (DisplayServer.SCREEN_SENSOR_LANDSCAPE = 4; the HUD is designed for 1280×720.)
window/handheld/orientation=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
