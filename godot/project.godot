; TORCH — Godot 4.2 project (renderer/shell over the Rust core, §26).
; Engine configuration file. Edited by hand for the toolchain de-risk; the editor
; will rewrite/extend it as scenes are added.

config_version=5

[application]

config/name="TORCH"
config/description="Hard sci-fi industrial sandbox. Godot shell over a Rust deterministic core."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
; Resizable so the desktop (PC mode) window can be sized/maximized; the HUD scales
; via the expand stretch below. Ignored on handhelds.
window/size/resizable=true
; Start in true fullscreen on desktop so it fills the screen even under a tiling WM
; (niri/sway ignore "maximize" and would leave a small window → a shrunk, tiny-font HUD).
; PC mode re-asserts this in code; F11 drops to a maximized window. (3 = Fullscreen;
; ignored on handhelds, which use the orientation/stretch settings below.)
window/size/mode=3
; Landscape, auto-rotating between the two landscape directions (mobile, §17).
; (DisplayServer.SCREEN_SENSOR_LANDSCAPE = 4; the HUD is designed for 1280×720.)
window/handheld/orientation=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
; Antialiasing so the thin orbit rings and body limbs don't read as stepped/jagged
; lines. 4× MSAA smooths the 3D geometry edges; FXAA cleans up the shader aliasing on
; the procedural surfaces. (The battle-diorama SubViewport opts out explicitly.)
anti_aliasing/quality/msaa_3d=2
anti_aliasing/quality/screen_space_aa=1
