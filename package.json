{
  "name": "torch-game",
  "version": "0.1.0",
  "description": "TORCH — headless deterministic simulation core (time, orbits, delta-v, living economy).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "tsx src/index.ts",
    "stability": "tsx src/tools/stabilityReport.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
